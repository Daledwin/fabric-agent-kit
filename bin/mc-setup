#!/usr/bin/env bash
# mc-setup — rend un projet de mod "cle en main" pour un agent :
#   1) supprime le footgun JDK : pose org.gradle.java.home=JDK21 (machine-globale) ;
#   2) cable le projet pour Claude Code : skills (symlinks), CLAUDE.md (onboarding), permissions.
# Apres ca : ouvrir une session d'agent dans le dossier du mod et dire "commencons le module" (ou /start-mod).
# Usage : mc-setup [dir] [--no-claude]
set -uo pipefail
KIT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KIT_ROOT="$(cd "$KIT_DIR/.." && pwd)"
# shellcheck source=_jdk.sh
. "$KIT_DIR/_jdk.sh"

# --- arguments ---
# Defaut NEUTRE (agent-agnostique) : seul le JDK est configure. Le cablage Claude Code
# (.claude/skills, CLAUDE.md pointeur, settings.json) ne se fait qu'avec --claude.
PROJ="."; WIRE=0
for a in "$@"; do
  case "$a" in
    --claude)    WIRE=1 ;;
    --no-claude) WIRE=0 ;;
    -*)          : ;;            # flag inconnu : ignore
    *)           PROJ="$a" ;;
  esac
done

# --- 1) JDK 21 pour gradle (et IntelliJ) ---
JDK="$(mc_find_jdk21)" || { echo "[mc-setup] JDK 21 introuvable ; pose MC_JDK=/chemin/jdk21." >&2; exit 1; }
echo "[mc-setup] JDK 21 : $JDK"

GP="$HOME/.gradle/gradle.properties"
mkdir -p "$HOME/.gradle"
LINE="org.gradle.java.home=$JDK"
if [ -f "$GP" ] && grep -q '^org\.gradle\.java\.home=' "$GP"; then
  echo "[mc-setup] org.gradle.java.home deja present dans $GP :"
  grep '^org\.gradle\.java\.home=' "$GP" | sed 's/^/             /'
  echo "[mc-setup] (laisse tel quel ; pour le changer -> $LINE)"
else
  printf '%s\n' "$LINE" >> "$GP"
  echo "[mc-setup] ajoute a $GP :"
  echo "             $LINE"
  echo "[mc-setup] -> ./gradlew (et IntelliJ) utilisent maintenant le JDK 21, sans prefixe JAVA_HOME."
fi

# --- 2) cablage agent (Claude Code) — OPT-IN via --claude ---
if [ "$WIRE" != 1 ]; then
  echo
  echo "[mc-setup] Conventions + protocole de demarrage (agent-agnostique) :"
  echo "             tools/fabric-agent-kit/AGENTS.md"
  echo "[mc-setup] Tout agent : lis AGENTS.md, puis dis « commençons le module »."
  echo "[mc-setup] (Claude Code) pour l'adaptateur skills/CLAUDE.md/permissions : mc-setup . --claude"
  exit 0
fi

PROJ_ABS="$(cd "$PROJ" 2>/dev/null && pwd)" || { echo "[mc-setup] projet introuvable : $PROJ" >&2; exit 1; }
echo
echo "[mc-setup] cablage du projet : $PROJ_ABS"

rel_path() { # $1 = depuis (dossier)  $2 = vers (chemin) -> chemin relatif
  if realpath --relative-to=/ / >/dev/null 2>&1; then
    realpath --relative-to="$1" "$2"
  else
    python3 -c 'import os,sys; print(os.path.relpath(sys.argv[2], sys.argv[1]))' "$1" "$2"
  fi
}

# 2a) skills en symlinks relatifs vers le submodule
mkdir -p "$PROJ_ABS/.claude/skills"
for s in mc-api run-mod new-mod start-mod; do
  src="$KIT_ROOT/claude-adapter/skills/$s"
  [ -d "$src" ] || continue
  link="$PROJ_ABS/.claude/skills/$s"
  tgt="$(rel_path "$PROJ_ABS/.claude/skills" "$src")"
  if [ -L "$link" ]; then
    ln -sfn "$tgt" "$link"; echo "             skill ~ /$s"
  elif [ -e "$link" ]; then
    echo "             skill ! /$s existe (non-symlink) -> laisse tel quel"
  else
    ln -s "$tgt" "$link"; echo "             skill + /$s"
  fi
done

# 2b) CLAUDE.md : POINTEUR FIN vers AGENTS.md (le cerveau, agent-agnostique, vit dans AGENTS.md).
#     On ne duplique pas le protocole ici ; Claude lit ce fichier -> il est renvoye vers AGENTS.md.
NAME="$(basename "$PROJ_ABS")"
FMJ="$PROJ_ABS/src/main/resources/fabric.mod.json"
if [ -f "$FMJ" ]; then
  n="$(grep -oE '"name"[[:space:]]*:[[:space:]]*"[^"]*"' "$FMJ" | head -1 | sed -E 's/.*"name"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/')"
  [ -n "${n:-}" ] && NAME="$n"
fi

CLAUDE="$PROJ_ABS/CLAUDE.md"
read -r -d '' BLOCK <<'EOF' || true
<!-- fabric-agent-kit:start -->
**Lis et applique `tools/fabric-agent-kit/AGENTS.md`** : conventions (MC 1.21.11 / Mojang / JDK21,
split client-serveur, regle d'or « verifier l'API avant d'ecrire ») **et** le protocole de demarrage.
Quand l'utilisateur dit « commençons le module », suis ce protocole (ou lance `/start-mod`).

Skills (confort, par-dessus `bin/*`) : `/mc-api` `/run-mod` `/new-mod` `/start-mod`.
<!-- fabric-agent-kit:end -->
EOF

if [ ! -f "$CLAUDE" ]; then
  { printf '# %s — mod Fabric\n\n' "$NAME"; printf '%s\n' "$BLOCK"; } > "$CLAUDE"
  echo "             CLAUDE.md + cree (pointeur fin -> AGENTS.md)"
elif ! grep -q 'fabric-agent-kit:start' "$CLAUDE"; then
  { printf '\n'; printf '%s\n' "$BLOCK"; } >> "$CLAUDE"
  echo "             CLAUDE.md ~ pointeur ajoute"
else
  echo "             CLAUDE.md = deja cable"
fi

# 2c) permissions -> .claude/settings.json (union de allow)
SNIP="$KIT_ROOT/claude-adapter/settings.snippet.json"
SET="$PROJ_ABS/.claude/settings.json"
if [ -f "$SNIP" ]; then
  if command -v jq >/dev/null 2>&1; then
    if [ -f "$SET" ]; then
      jq --slurpfile s "$SNIP" \
        '.permissions.allow = (((.permissions.allow // []) + ($s[0].permissions.allow // [])) | unique)' \
        "$SET" > "$SET.tmp" && mv "$SET.tmp" "$SET"
      echo "             settings.json ~ permissions fusionnees"
    else
      jq '.' "$SNIP" > "$SET"
      echo "             settings.json + cree"
    fi
  else
    if [ -f "$SET" ]; then
      echo "             settings.json ! jq absent -> fusionne ces permissions a la main :"
      sed 's/^/               /' "$SNIP"
    else
      cp "$SNIP" "$SET"
      echo "             settings.json + cree (copie)"
    fi
  fi
fi

echo
echo "[mc-setup] OK projet cable. Ouvre une session d'agent ici et dis « commençons le module » (ou /start-mod)."
