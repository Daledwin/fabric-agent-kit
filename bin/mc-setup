#!/usr/bin/env bash
# mc-setup — configure le JDK et (optionnellement) cable le projet pour un/des agent(s).
#   defaut          : NEUTRE — pose org.gradle.java.home=JDK21 (machine-globale) ; pointe vers AGENTS.md.
#   --claude        : adaptateur Claude Code (skills symlinks, CLAUDE.md pointeur, permissions).
#   --agents|--multi: pointeurs fins multi-agents (AGENTS.md racine, CLAUDE.md, GEMINI.md, .cursorrules,
#                     .github/copilot-instructions.md) -> tous renvoient vers le AGENTS.md du kit (le cerveau).
# Le cerveau (conventions + protocole de demarrage) vit dans tools/fabric-agent-kit/AGENTS.md, jamais duplique.
# Usage : mc-setup [dir] [--claude] [--agents]
set -uo pipefail
KIT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KIT_ROOT="$(cd "$KIT_DIR/.." && pwd)"
# shellcheck source=_jdk.sh
. "$KIT_DIR/_jdk.sh"

# --- arguments ---
PROJ="."; CLAUDE_ADAPTER=0; MULTI=0
for a in "$@"; do
  case "$a" in
    --claude)               CLAUDE_ADAPTER=1 ;;
    --no-claude)            CLAUDE_ADAPTER=0 ;;
    --agents|--multi|--all-agents) MULTI=1 ;;
    -*)                     : ;;            # flag inconnu : ignore
    *)                      PROJ="$a" ;;
  esac
done

# --- 1) JDK 21 pour gradle (et IntelliJ) ---
JDK="$(mc_find_jdk21)" || { echo "[mc-setup] JDK 21 introuvable ; pose MC_JDK=/chemin/jdk21." >&2; exit 1; }
echo "[mc-setup] JDK 21 : $JDK"

GP="$HOME/.gradle/gradle.properties"
mkdir -p "$HOME/.gradle"
LINE="org.gradle.java.home=$JDK"
if [ -f "$GP" ] && grep -q '^org\.gradle\.java\.home=' "$GP"; then
  echo "[mc-setup] org.gradle.java.home deja present dans $GP :"
  grep '^org\.gradle\.java\.home=' "$GP" | sed 's/^/             /'
  echo "[mc-setup] (laisse tel quel ; pour le changer -> $LINE)"
else
  printf '%s\n' "$LINE" >> "$GP"
  echo "[mc-setup] ajoute a $GP :"
  echo "             $LINE"
  echo "[mc-setup] -> ./gradlew (et IntelliJ) utilisent maintenant le JDK 21, sans prefixe JAVA_HOME."
fi

# --- 2) cablage agent — OPT-IN ---
if [ "$CLAUDE_ADAPTER" != 1 ] && [ "$MULTI" != 1 ]; then
  echo
  echo "[mc-setup] Conventions + protocole de demarrage (agent-agnostique) :"
  echo "             tools/fabric-agent-kit/AGENTS.md"
  echo "[mc-setup] Tout agent : lis AGENTS.md, puis dis « commençons le module »."
  echo "[mc-setup] Cablage optionnel :"
  echo "             --claude   adaptateur Claude Code (skills, CLAUDE.md, permissions)"
  echo "             --agents   pointeurs multi-agents (AGENTS.md, CLAUDE.md, GEMINI.md, .cursorrules, copilot)"
  exit 0
fi

PROJ_ABS="$(cd "$PROJ" 2>/dev/null && pwd)" || { echo "[mc-setup] projet introuvable : $PROJ" >&2; exit 1; }
echo
echo "[mc-setup] cablage du projet : $PROJ_ABS"

rel_path() { # $1 = depuis (dossier)  $2 = vers (chemin) -> chemin relatif
  if realpath --relative-to=/ / >/dev/null 2>&1; then
    realpath --relative-to="$1" "$2"
  else
    python3 -c 'import os,sys; print(os.path.relpath(sys.argv[2], sys.argv[1]))' "$1" "$2"
  fi
}

# nom lisible (pour le titre des pointeurs neufs)
NAME="$(basename "$PROJ_ABS")"
FMJ="$PROJ_ABS/src/main/resources/fabric.mod.json"
if [ -f "$FMJ" ]; then
  n="$(grep -oE '"name"[[:space:]]*:[[:space:]]*"[^"]*"' "$FMJ" | head -1 | sed -E 's/.*"name"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/')"
  [ -n "${n:-}" ] && NAME="$n"
fi

# chemin (relatif a la racine projet) vers le cerveau
AGENTS_REL="$(rel_path "$PROJ_ABS" "$KIT_ROOT")/AGENTS.md"

# bloc-pointeur generique (valable pour TOUT agent) ; le cerveau reste AGENTS.md
POINTER="$(cat <<EOF
<!-- fabric-agent-kit:start -->
**Lis et applique \`$AGENTS_REL\`** — conventions (MC 1.21.11 / Mojang / JDK21, split client-serveur,
regle d'or « verifier l'API avant d'ecrire ») ET le protocole de demarrage du mod.
Quand l'utilisateur dit « commençons le module » / « start the mod », suis ce protocole.
<!-- fabric-agent-kit:end -->
EOF
)"

write_pointer() { # $1 = fichier cible
  local f="$1" dir
  dir="$(dirname "$f")"; mkdir -p "$dir"
  if [ -f "$f" ] && grep -q 'fabric-agent-kit:start' "$f"; then
    sed '/fabric-agent-kit:start/,/fabric-agent-kit:end/d' "$f" > "$f.tmp"
    printf '%s\n' "$POINTER" >> "$f.tmp" && mv "$f.tmp" "$f"
    echo "             ~ ${f#"$PROJ_ABS"/}"
  elif [ -f "$f" ]; then
    { printf '\n'; printf '%s\n' "$POINTER"; } >> "$f"
    echo "             ~ ${f#"$PROJ_ABS"/} (bloc ajoute)"
  else
    { printf '# %s — mod Fabric\n\n' "$NAME"; printf '%s\n' "$POINTER"; } > "$f"
    echo "             + ${f#"$PROJ_ABS"/}"
  fi
}

# 2a) pointeurs multi-agents (hors CLAUDE.md, gere juste apres pour les deux modes)
if [ "$MULTI" = 1 ]; then
  echo "[mc-setup] pointeurs multi-agents -> $AGENTS_REL"
  write_pointer "$PROJ_ABS/AGENTS.md"                       # standard agents.md (Codex, etc.)
  write_pointer "$PROJ_ABS/GEMINI.md"                       # Gemini CLI
  write_pointer "$PROJ_ABS/.cursorrules"                    # Cursor (legacy, toujours supporte)
  write_pointer "$PROJ_ABS/.github/copilot-instructions.md" # GitHub Copilot
fi

# 2b) CLAUDE.md : pointeur fin (des que --claude OU --agents)
if [ "$CLAUDE_ADAPTER" = 1 ] || [ "$MULTI" = 1 ]; then
  write_pointer "$PROJ_ABS/CLAUDE.md"
fi

# 2c) adaptateur Claude riche : skills (symlinks) + permissions
if [ "$CLAUDE_ADAPTER" = 1 ]; then
  echo "[mc-setup] adaptateur Claude Code"
  mkdir -p "$PROJ_ABS/.claude/skills"
  for s in mc-api run-mod new-mod start-mod; do
    src="$KIT_ROOT/claude-adapter/skills/$s"
    [ -d "$src" ] || continue
    link="$PROJ_ABS/.claude/skills/$s"
    tgt="$(rel_path "$PROJ_ABS/.claude/skills" "$src")"
    if [ -L "$link" ]; then
      ln -sfn "$tgt" "$link"; echo "             skill ~ /$s"
    elif [ -e "$link" ]; then
      echo "             skill ! /$s existe (non-symlink) -> laisse tel quel"
    else
      ln -s "$tgt" "$link"; echo "             skill + /$s"
    fi
  done

  SNIP="$KIT_ROOT/claude-adapter/settings.snippet.json"
  SET="$PROJ_ABS/.claude/settings.json"
  if [ -f "$SNIP" ]; then
    if command -v jq >/dev/null 2>&1; then
      if [ -f "$SET" ]; then
        jq --slurpfile s "$SNIP" \
          '.permissions.allow = (((.permissions.allow // []) + ($s[0].permissions.allow // [])) | unique)' \
          "$SET" > "$SET.tmp" && mv "$SET.tmp" "$SET"
        echo "             settings.json ~ permissions fusionnees"
      else
        jq '.' "$SNIP" > "$SET"
        echo "             settings.json + cree"
      fi
    else
      if [ -f "$SET" ]; then
        echo "             settings.json ! jq absent -> fusionne ces permissions a la main :"
        sed 's/^/               /' "$SNIP"
      else
        cp "$SNIP" "$SET"
        echo "             settings.json + cree (copie)"
      fi
    fi
  fi
fi

echo
echo "[mc-setup] OK projet cable. Ouvre une session d'agent ici et dis « commençons le module »."
